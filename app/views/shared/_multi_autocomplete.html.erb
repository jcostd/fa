<% frame_id = local_assigns[:wrapper_id] || "multi_autocomplete_#{SecureRandom.hex(4)}" %>

<fieldset class="fieldset" data-controller="multi-autocomplete">
  <legend class="fieldset-legend"><%= label %></legend>

  <%# Contenitore dei Badge Selezionati %>
  <div data-multi-autocomplete-target="selectedContainer" class="flex flex-wrap gap-2 mb-2">
    <% selected_items.each do |item| %>
      <div class="badge badge-primary gap-2" data-id="<%= item.id %>">
        <%= item.respond_to?(:display_name) ? item.display_name : item.name %>
        <button type="button" data-action="click->multi-autocomplete#removeRow" class="hover:text-error text-xs font-bold">X</button>
        <input type="hidden" name="<%= form.object_name %>[<%= field %>][]" value="<%= item.id %>">
      </div>
    <% end %>
  </div>

  <%# Input di Ricerca integrato con Turbo %>
  <div class="dropdown w-full">
    <%= form_with url: search_url, method: :get,
                  data: {
                    turbo_frame: frame_id,
                    controller: "autosubmit",
                    action: "input->autosubmit#submit"
                  } do |f| %>

      <%= f.hidden_field :frame_id, value: frame_id %>

      <%= f.text_field :query,
       class: "input w-full",
       data: { multi_autocomplete_target: "input" },
       autocomplete: "off",
       placeholder: "Cerca o aggiungi nuovo..." %>
    <% end %>

    <%= turbo_frame_tag frame_id, class: "dropdown-content w-full z-[1]" %>
  </div>

  <template data-multi-autocomplete-target="badgeTemplate">
    <div class="badge badge-primary gap-2" data-id="TEMPLATE_ID">
      TEMPLATE_NAME
      <button type="button" data-action="click->multi-autocomplete#removeRow" class="hover:text-error text-xs font-bold">X</button>
      <input type="hidden" name="<%= form.object_name %>[<%= field %>][]" value="TEMPLATE_ID">
    </div>
  </template>
</fieldset>
