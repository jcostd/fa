<% form_url = local_assigns.fetch(:submit_url, contacts_path) %>

<%= form_with model: contact, url: form_url,
              data: { controller: "contact-form" } do |f| %>

  <%= render "shared/form_errors", object: contact %>

  <% if local_assigns[:modal_id].present? %>
    <%= hidden_field_tag :modal_id, local_assigns[:modal_id] %>
    <%= hidden_field_tag :target_list_id, local_assigns[:target_list_id] %>
    <%= hidden_field_tag :role, local_assigns[:role] %>
  <% end %>

  <fieldset class="fieldset">
    <legend class="fieldset-legend text-lg font-semibold">Tipo di soggetto</legend>

    <div class="flex gap-6 my-3">
      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :kind, "person", class: "radio radio-primary",
		      data: { action: "change->contact-form#toggle", contact_form_target: "personRadio" } %>
        <span class="label-text font-medium">Persona fisica</span>
      </label>

      <label class="flex items-center gap-2 cursor-pointer">
        <%= f.radio_button :kind, "company", class: "radio radio-primary",
              data: { action: "change->contact-form#toggle", contact_form_target: "companyRadio" } %>
        <span class="label-text font-medium">Azienda / Ente / Associazione</span>
      </label>
    </div>
  </fieldset>

  <div data-contact-form-target="personFields" class="<%= 'hidden' if contact.kind == 'company' %>">
    <fieldset class="fieldset">
      <legend class="fieldset-legend">Dati anagrafici personali</legend>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :first_name, "Nome *", class: "label" %>
          <%= f.text_field :first_name, class: "input w-full", placeholder: "Mario" %>
        </div>

        <div>
          <%= f.label :last_name, "Cognome *", class: "label" %>
          <%= f.text_field :last_name, class: "input w-full", placeholder: "Rossi" %>
        </div>
      </div>
    </fieldset>
  </div>

  <div data-contact-form-target="companyFields" class="<%= 'hidden' if contact.kind == 'person' || contact.kind.blank? %>">
    <fieldset class="fieldset">
      <legend class="fieldset-legend">Ragione sociale / Denominazione *</legend>

      <%= f.text_field :company_name, class: "input w-full",
          placeholder: "Es. Rossi Srl, Comune di Milano, Studio Legale Bianchi" %>
    </fieldset>
  </div>

  <fieldset class="fieldset mt-6">
    <legend class="fieldset-legend">Contatti</legend>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :email, "Email", class: "label" %>
        <%= f.email_field :email, class: "input w-full", placeholder: "nome@esempio.it" %>
      </div>

      <div>
        <%= f.label :phone, "Telefono / Cellulare", class: "label" %>
        <%= f.text_field :phone, class: "input w-full", placeholder: "+39 333 123 4567" %>
      </div>
    </div>
  </fieldset>

  <fieldset class="fieldset mt-2">
    <legend class="fieldset-legend">Codice fiscale / Partita IVA</legend>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div data-contact-form-target="taxIdField">
        <%= f.label :tax_id, "Codice Fiscale", class: "label" %>
        <%= f.text_field :tax_id, class: "input w-full", placeholder: "RSSMRA80A01H501Z" %>
        <p class="text-xs text-base-content/70 mt-1" data-contact-form-target="personHint">
          Obbligatorio per persone fisiche
        </p>
      </div>

      <div>
        <%= f.label :vat_number, "Partita IVA", class: "label" %>
        <%= f.text_field :vat_number, class: "input w-full", placeholder: "12345678901" %>
        <p class="text-xs text-base-content/70 mt-1" data-contact-form-target="companyHint hidden">
          Obbligatoria per aziende / partite IVA
        </p>
      </div>
    </div>
  </fieldset>

  <!-- Begin Actions -->
  <div class="modal-action">

    <%= f.submit "Salva", class: "btn btn-primary" %>

    <button
      type="button"
      class="btn"
      data-action="dialog#close">
      Chiudi
    </button>

  </div>
  <!-- End Actions -->
<% end %>
