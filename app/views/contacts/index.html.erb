<%= turbo_stream_from "contacts" %>

<div class="max-w-7xl mx-auto pb-12 px-4 sm:px-6 lg:px-8">

  <%# Begin of Header %>
  <div class="mt-6 mb-8">

    <div class="flex flex-row items-center justify-between gap-4">

      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold">Contatti</h1>
        <div class="badge badge-ghost font-medium">
          <%= @total_contacts %> totali
        </div>
      </div>

      <%# Bottone Nuovo Contatto %>
      <div class="flex-none">
        <%= link_to new_contact_path,
		    class: "btn btn-primary btn-sm",
		    data: { turbo_frame: "modal" } do %>
          <%= icon("plus", classes: "size-4") %>
          <span class="hidden sm:inline">Nuovo Contatto</span>
        <% end %>
      </div>

    </div>

    <p class="mt-2 text-sm text-base-content/70">
      Gestisci la tua rubrica. Aggiungi nuove persone o aziende, cerca e mantieni aggiornati i loro dati.
    </p>

  </div>
  <%# End of Header %>

  <%# 2. TOOLBAR UNIFICATA %>
  <%= form_with url: contacts_path,
		method: :get,
		class: "flex flex-col md:flex-row md:items-center gap-4 mb-6",
		data: {
		  turbo_frame: "contacts_list",
		  turbo_action: "advance",
		  controller: "autosubmit"
		} do |f| %>

    <%# Ricerca testuale %>
    <label class="input input-sm flex items-center w-full md:w-72 shrink-0">
      <%= icon("search", classes: "size-4 opacity-50") %>
      <%= f.search_field :query,
       value: params[:query],
       class: "grow",
       autocomplete: "off",
       placeholder: "Cerca contatto...",
       data: { action: "input->autosubmit#submit keydown.enter->autosubmit#prevent" } %>
    </label>

    <div class="flex flex-row items-center justify-between gap-4 w-full md:grow">

      <%# Begin of Filters %>
      <div class="join">

	<%= f.radio_button :filter,
         '',
         checked: params[:filter].blank?,
         class: "join-item btn btn-sm",
         aria: {
           label: "Tutti"
         },
         data: {
           action: "change->autosubmit#submit"
         }
	%>

	<%= f.radio_button :filter,
         "person",
         checked: params[:filter] == "person",
         class: "join-item btn btn-sm",
         aria: {
           label: "Persone"
         },
         data: {
           action: "change->autosubmit#submit"
         }
	%>

	<%= f.radio_button :filter,
         "company",
         checked: params[:filter] == "company",
         class: "join-item btn btn-sm",
         aria: {
           label: "Aziende"
         },
         data: {
           action: "change->autosubmit#submit"
         }
	%>

      </div>
      <%# End of Filters %>

      <%= f.select :sort,
          options_for_select([['Più recenti', 'recent'], ['Alfabetico', 'alpha']], params[:sort] || 'recent'),
       {},
       {
	 class: "select select-sm md:ml-auto w-full md:w-auto cursor-pointer",
	 data: {
	   action: "change->autosubmit#submit"
	 }
       }
      %>
    </div>

  <% end %>
  <%# End of Toolbar %>

  <%# WRAPPER TURBO %>
  <%= turbo_frame_tag "contacts_list" do %>

    <% if params[:query].present? || params[:filter].present? %>
      <div class="mb-4 text-sm font-medium text-base-content/70 flex items-center gap-2 animate-fade-in">
        <%= icon("check_circle", classes: "size-4 text-success") %>
        <span>
          Trovati <strong class="text-base-content"><%= @pagy.count %></strong> risultati
          <% if params[:query].present? %>
            per "<span class="italic"><%= params[:query] %></span>"
          <% end %>
        </span>
      </div>
    <% end %>

    <%# Begin of List %>
    <% if @contacts.any? %>

      <ul class="list bg-base-100 rounded-box shadow-md">

        <li class="p-4 pb-2 text-xs opacity-60 tracking-wide flex justify-between items-end">
          <span>Rubrica</span>
          <span class="tracking-normal"><%= @pagy.count %> voci</span>
        </li>

        <%= render @contacts %>
      </ul>

    <% else %>

      <div class="hero bg-base-100 rounded-box shadow-md py-16">
        <div class="hero-content text-center">
          <div class="max-w-md">
            <%= icon("users", classes: "size-12 opacity-20 mx-auto mb-4") %>
            <h2 class="text-xl font-bold">Nessun risultato</h2>
            <% if params[:query].present? %>
              <p class="py-4 opacity-60">Non abbiamo trovato nulla per "<strong><%= params[:query] %></strong>". Prova a cercare con termini diversi.</p>
            <% else %>
              <p class="py-4 opacity-60">La tua rubrica è vuota. Inizia ad aggiungere i tuoi clienti o collaboratori.</p>
            <% end %>
          </div>
        </div>
      </div>

    <% end %>
    <%# End of List %>

    <%# La paginazione resta qui dentro %>
    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <%== @pagy.series_nav(:daisyui) %>
      </div>
    <% end %>

  <% end %>
  <%# End of Wrapper %>

</div>
