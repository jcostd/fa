<div id="<%= dom_id(job) %>" class="group relative flex items-center justify-between p-3 sm:p-4 bg-base-100 border border-base-200 hover:border-primary/40 rounded-box transition-all duration-200">

  <%= link_to "", job, class: "absolute inset-0 z-10 focus:outline-none rounded-box" %>

  <div class="flex flex-col gap-0.5 pr-4 truncate z-20 pointer-events-none">
    <span class="font-semibold text-base-content group-hover:text-primary transition-colors truncate">
      <%= job.display_title %>
    </span>

    <span class="text-xs text-base-content/60 flex items-center gap-1 truncate">
      <%= icon("location", classes: "w-3 h-3 flex-shrink-0") %>
      <%= job.display_location %>
    </span>
  </div>

  <div class="flex items-center gap-4 z-20 pointer-events-none shrink-0">
    <div class="text-right flex flex-col items-end">
      <span class="text-sm font-medium text-base-content">
        <%= job.date.strftime("%d/%m/%Y") %>
      </span>

      <% if job.start_at.present? %>
        <span class="text-xs text-base-content/50"><%= job.start_at.strftime("%H:%M") %></span>
      <% elsif job.legacy_from_time.present? %> <span class="text-xs text-base-content/50"><%= job.legacy_from_time.strftime("%H:%M") %> (legacy)</span>
      <% end %>
    </div>

    <%= icon("chevron_right", classes: "w-5 h-5 text-base-300 group-hover:text-primary transition-colors") %>
  </div>
</div>
