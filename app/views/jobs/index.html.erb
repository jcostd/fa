<%= turbo_stream_from "jobs" %>

<div class="max-w-7xl mx-auto pb-12 px-4 sm:px-6 lg:px-8">

  <%# Begin of Header %>
  <div class="mt-6 mb-8">

    <div class="flex flex-row items-center justify-between gap-4">

      <div class="flex items-center gap-3">
        <h1 class="text-3xl font-bold">Servizi</h1>
        <div class="badge badge-ghost font-medium">
          <%= @total_jobs %> totali
        </div>
      </div>

      <%# Bottone Nuovo Servizio (Job) %>
      <div class="flex-none">
        <%= link_to new_job_path,
		    class: "btn btn-primary btn-sm" do %>
          <%= icon("plus", classes: "size-4") %>
          <span class="hidden sm:inline">Nuovo Servizio</span>
        <% end %>
      </div>

    </div>

    <p class="mt-2 text-sm text-base-content/70">
      Pianifica e gestisci i tuoi servizi fotografici o video. Tieni traccia delle date e dei collaboratori.
    </p>

  </div>
  <%# End of Header %>

  <%# 2. TOOLBAR UNIFICATA %>
  <%= render "jobs/filter_bar", target_url: jobs_path, turbo_frame: "jobs_list" %>

  <%# WRAPPER TURBO %>
  <%= turbo_frame_tag "jobs_list" do %>

    <% if params[:query].present? || params[:period].present? || params[:video].present? %>
      <div class="mb-4 text-sm font-medium text-base-content/70 flex items-center gap-2 animate-fade-in">
        <%= icon("check_circle", classes: "size-4 text-success") %>
        <span>
          Trovati <strong class="text-base-content"><%= @pagy.count %></strong> servizi
          <% if params[:query].present? %>
            per "<span class="italic"><%= params[:query] %></span>"
          <% end %>
        </span>
      </div>
    <% end %>

    <%# Begin of List %>
    <% if @jobs.any? %>

      <ul class="list bg-base-100 rounded-box shadow-md">

        <li class="p-4 pb-2 text-xs opacity-60 tracking-wide flex justify-between items-end">
          <span>Servizi Programmati</span>
          <span class="tracking-normal"><%= @pagy.count %> voci</span>
        </li>

        <%= render @jobs %>
      </ul>

    <% else %>

      <div class="hero bg-base-100 rounded-box shadow-md py-16">
        <div class="hero-content text-center">
          <div class="max-w-md">
            <%= icon("photo_library", classes: "size-12 opacity-20 mx-auto mb-4") %>
            <h2 class="text-xl font-bold">Nessun servizio trovato</h2>
            <% if params[:query].present? || params[:period].present? || params[:video].present? %>
              <p class="py-4 opacity-60">Non abbiamo trovato nulla con i filtri attuali. Prova a modificare la ricerca.</p>
            <% else %>
              <p class="py-4 opacity-60">Il tuo calendario è vuoto. Inizia a pianificare il tuo primo servizio fotografico.</p>
            <% end %>
          </div>
        </div>
      </div>

    <% end %>
    <%# End of List %>

    <%# La paginazione resta qui dentro %>
    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <%== @pagy.series_nav(:daisyui) %>
      </div>
    <% end %>

  <% end %>
  <%# End of Wrapper %>

</div>
