<header class="navbar bg-base-100 shadow-sm px-4 lg:px-8 z-50">

  <div class="navbar-start">
    <%= link_to root_path, class: "btn btn-ghost text-xl normal-case" do %>
      📸 StudioApp
    <% end %>
  </div>

  <div class="navbar-center hidden lg:flex flex-1 max-w-xl mx-4">
    <label class="input input-bordered flex items-center gap-2 w-full bg-base-200 focus-within:bg-base-100 transition-colors">
      <%= icon("search", classes: "w-5 h-5 opacity-70") %>

      <input type="text"
             class="grow"
             placeholder="Cerca lavori, contatti, location..."
	     data-turbo-permanent="true"
             data-controller="omnibox"
             data-action="keydown@window->omnibox#focusShortcut" />

      <kbd class="kbd kbd-sm">⌘</kbd>
      <kbd class="kbd kbd-sm">K</kbd>
    </label>
  </div>

  <div class="navbar-end gap-2">
    <%= link_to new_job_path, class: "btn btn-primary btn-sm" do %>
      <%= icon("add", classes: "w-4 h-4") %>
      <span class="hidden sm:inline">Nuovo Lavoro</span>
    <% end %>

    <div class="dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
        <div class="w-9 rounded-full bg-neutral text-neutral-content flex items-center justify-center">
          <span class="text-sm font-bold">U</span>
        </div>
      </div>
      <ul tabindex="0" class="mt-3 z-[1] p-2 shadow menu menu-sm dropdown-content bg-base-100 rounded-box w-52">
        <li><%= link_to "Impostazioni", "#" %></li>
        <li><%= link_to "Esci", "#", data: { turbo_method: :delete } %></li>
      </ul>
    </div>
  </div>
</header>
