<%# Parametri attesi: query, js_controller, frame_id %>

<%= turbo_frame_tag local_assigns[:frame_id] do %>
  <%# Contenitore principale: nasconde gli overflow e gestisce i bordi arrotondati %>
  <div class="bg-base-100 shadow-xl rounded-box border border-base-200 w-full flex flex-col overflow-hidden mt-1 z-10">

    <%# Area scrollabile: solo i risultati scorrono qui dentro %>
    <ul tabindex="0" class="menu flex-nowrap overflow-y-auto max-h-60 w-full p-2">
      <%= yield %>
    </ul>

    <%# Footer fisso per la creazione %>
    <% if local_assigns[:query].present? %>
      <div class="p-2 border-t border-base-200 bg-base-100">
        <button type="button"
                class="btn btn-ghost btn-sm w-full justify-start text-primary hover:bg-primary/10"
                data-action="click-><%= local_assigns[:js_controller] %>#openModal"
                data-query="<%= local_assigns[:query] %>">
          <%= icon("plus", classes: "size-4 me-1") %>
          <span class="truncate">Crea "<%= local_assigns[:query] %>"...</span>
        </button>
      </div>
    <% end %>

  </div>
<% end %>
