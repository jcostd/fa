<div class="max-w-7xl mx-auto pb-12 px-4 sm:px-6 lg:px-8">

  <%# Subtle Back Link %>
  <div class="mt-6 mb-2">
    <%= link_to locations_path, class: "inline-flex items-center gap-1.5 text-sm font-medium text-base-content/50 hover:text-base-content transition-colors" do %>
      <%= icon("chevron_left", classes: "size-4") %>
      <span>Torna alle Posizioni</span>
    <% end %>
  </div>

  <%# Begin of Header REFINED FLOW %>
  <div class="mb-8 flex flex-col sm:flex-row sm:items-start justify-between gap-5">

    <%# BLOCCO SINISTRA: Identità e Contesto (Tutto raggruppato) %>
    <div class="flex flex-col gap-2 flex-1 min-w-0">

      <%# Titolo e Badge %>
      <div class="flex items-center flex-wrap gap-2">
        <h1 class="text-2xl sm:text-3xl font-bold break-words"><%= @location.name %></h1>
        <% if @location.district.present? %>
          <div class="badge badge-neutral whitespace-nowrap"><%= @location.district %></div>
        <% end %>
        <div class="badge badge-ghost font-medium whitespace-nowrap hidden sm:inline-flex">
          <%= @total_location_jobs %> servizi totali
        </div>
      </div>

      <%# Descrizione: ora è logicamente agganciata al titolo, non isolata %>
      <p class="text-sm text-base-content/70">
        Dettaglio della posizione e storico di tutti i servizi associati a questo luogo.
      </p>

    </div>

    <%# BLOCCO DESTRA: Azioni (A destra su desktop, a capo su mobile) %>
    <div class="flex items-center gap-2 shrink-0 pt-1">
      <%= link_to edit_location_path(@location), class: "btn btn-outline btn-sm", data: { turbo_frame: "modal" } do %>
        <%= icon("edit", classes: "size-4") %>
        <span class="hidden sm:inline">Modifica</span>
      <% end %>
      <%= button_to location_path(@location), method: :delete, class: "btn btn-ghost text-error btn-sm hover:bg-error/10", form: { data: { turbo_confirm: "Sei sicuro di voler eliminare questa posizione?" } } do %>
        <%= icon("trash", classes: "size-4") %>
      <% end %>
    </div>

  </div>
  <%# End of Header %>

  <%# 2. TOOLBAR MINI-INDEX %>
  <%= render "jobs/filter_bar", target_url: location_path(@location), turbo_frame: "location_jobs_list" %>

  <%# WRAPPER TURBO %>
  <%= turbo_frame_tag "location_jobs_list" do %>

    <%# Feedback Risultati Ricerca %>
    <% if params[:query].present? || params[:period].present? || params[:video].present? %>
      <div class="mb-4 text-sm font-medium text-base-content/70 flex items-center gap-2 animate-fade-in">
        <%= icon("check_circle", classes: "size-4 text-success") %>
        <span>
          Trovati <strong class="text-base-content"><%= @pagy.count %></strong> servizi
          <% if params[:query].present? %>
            per "<span class="italic"><%= params[:query] %></span>"
          <% end %>
        </span>
      </div>
    <% end %>

    <%# Begin of List %>
    <% if @jobs.any? %>

      <ul class="list bg-base-100 rounded-box shadow-md">
        <li class="p-4 pb-2 text-xs opacity-60 tracking-wide flex justify-between items-end">
          <span>Storico Servizi</span>
          <span class="tracking-normal"><%= @pagy.count %> voci</span>
        </li>

        <%= render partial: "jobs/job", collection: @jobs %>
      </ul>

    <% else %>

      <%# Empty State Hero %>
      <div class="hero bg-base-100 rounded-box shadow-md py-16">
        <div class="hero-content text-center">
          <div class="max-w-md">
            <%= icon("photo_library", classes: "size-12 opacity-20 mx-auto mb-4") %>
            <h2 class="text-xl font-bold">Nessun servizio</h2>
            <% if params[:query].present? %>
              <p class="py-4 opacity-60">
                Non abbiamo trovato nessun servizio per "<strong><%= params[:query] %></strong>" in questa location.</p>
            <% else %>
              <p class="py-4 opacity-60">
                Non ci sono ancora servizi registrati per questa posizione. Quando assegnerai questa posizione a un servizio, lo vedrai comparire qui.</p>
            <% end %>
          </div>
        </div>
      </div>

    <% end %>
    <%# End of List %>

    <%# Paginazione %>
    <% if @pagy.pages > 1 %>
      <div class="mt-8 flex justify-center">
        <%== @pagy.series_nav(:daisyui) %>
      </div>
    <% end %>

  <% end %>
  <%# End of Wrapper %>

</div>
