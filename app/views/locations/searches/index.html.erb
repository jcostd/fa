<% if @locations.any? %>
  <ul class="menu bg-base-200 w-full rounded-box">
    <% @locations.each do |location| %>
      <li>
        <a href="#"
           data-action="click->multi-autocomplete#select"
           data-id="<%= location.id %>"
           data-name="<%= location.name %>">
          <%= location.name %>
        </a>
      </li>
    <% end %>

    <%# --- Pulsante Crea Nuovo --- %>
    <li class="border-t border-base-300 mt-2">
      <a href="#" class="text-primary font-bold" data-action="click->multi-autocomplete#openModal">
        <%= icon("plus", classes: "w-4 h-4") %> Nuova Location
      </a>
    </li>
  </ul>

<% else %>
  <ul class="menu bg-base-200 w-full rounded-box">
    <li><span class="text-base-content/50">Nessuna location trovata.</span></li>
    <li class="border-t border-base-300 mt-2">
      <a href="#" class="text-primary font-bold" data-action="click->multi-autocomplete#openModal">
        <%= icon("plus", classes: "w-4 h-4") %> Nuova Location
      </a>
    </li>
  </ul>
<% end %>
