<%= turbo_stream_from @user %>

<div id="<%= dom_id(@user) %>" class="max-w-4xl mx-auto pb-12 px-4 sm:px-6 lg:px-8">

  <%# 2. HEADER ENTITÀ REFINED FLOW %>
  <div class="mb-8 flex flex-col sm:flex-row sm:items-start justify-between gap-5">

    <%# BLOCCO SINISTRA: Avatar e Info %>
    <div class="flex items-center gap-4 flex-1 min-w-0">

      <div class="avatar avatar-placeholder shrink-0">
        <div class="bg-primary/10 text-primary rounded-full w-14 h-14 sm:w-16 sm:h-16">
          <span class="text-xl sm:text-2xl font-bold"><%= @user.display_name.first(2).upcase %></span>
        </div>
      </div>

      <div class="flex flex-col min-w-0">
        <h1 class="text-2xl sm:text-3xl font-extrabold break-words truncate tracking-tight">
          @<%= @user.display_name %>
        </h1>
        <div class="flex items-center gap-2 mt-1">
          <div class="badge badge-primary badge-outline badge-sm font-bold whitespace-nowrap">UTENTE SISTEMA</div>
        </div>
      </div>

    </div>

    <%# BLOCCO DESTRA: Azioni Profilo %>
    <div class="flex items-center gap-2 shrink-0 pt-1">
      <%= link_to edit_user_path(@user), class: "btn btn-outline btn-sm", data: { turbo_frame: "modal" } do %>
        <%= icon("edit", classes: "size-4") %>
        <span class="hidden sm:inline">Modifica Profilo</span>
      <% end %>
    </div>

  </div>


  <%# ========================================== %>
  <%# BODY: Sessioni e Dispositivi               %>
  <%# ========================================== %>
  <div class="flex flex-col gap-5">

    <%# Intestazione Sezione %>
    <div class="flex items-end justify-between px-1">
      <div>
        <h2 class="text-xl font-bold">Dispositivi Connessi</h2>
        <p class="text-sm opacity-60 mt-0.5">Sessioni di accesso attive collegate a questo account.</p>
      </div>
      <div class="badge badge-neutral"><%= @user.sessions.size %> attive</div>
    </div>

    <%# Nuova Lista DaisyUI V5 %>
    <ul class="list bg-base-100 rounded-box shadow-sm border border-base-200">

      <li class="p-4 pb-2 text-xs font-bold opacity-50 uppercase tracking-wider">Sessioni Recenti</li>

      <% if @user.sessions.any? %>
        <% @user.sessions.sort_by(&:created_at).reverse.each do |session| %>

          <li class="list-row items-center group hover:bg-base-200/50 transition-colors">

            <%# Icona Dispositivo %>
            <div>
              <div class="avatar shrink-0">
                <div class="w-10 flex items-center justify-center bg-base-200/50 text-base-content/60 rounded-xl">
                  <%= icon("monitor_smartphone", classes: "size-5") %>
                </div>
              </div>
            </div>

            <%# Colonna principale elastica (.list-col-grow) %>
            <div class="list-col-grow min-w-0">
              <div class="font-bold text-sm truncate" title="<%= session.user_agent %>">
                <%= session.user_agent.presence || "Dispositivo Sconosciuto" %>
              </div>

              <div class="text-xs opacity-60 flex items-center gap-2 mt-1 truncate">
                <span class="font-mono bg-base-200 px-1.5 py-0.5 rounded text-[10px]">
                  IP: <%= session.ip_address.presence || "N/D" %>
                </span>
                <span>&bull;</span>
                <span><%= time_ago_in_words(session.created_at) %> fa</span>
              </div>
            </div>

          </li>

        <% end %>
      <% else %>
        <li class="list-row items-center justify-center text-center opacity-50 p-8">
          <div class="flex flex-col items-center">
            <%= icon("shield", classes: "size-8 mb-2 opacity-40") %>
            <span class="text-sm italic">Nessuna sessione registrata.</span>
          </div>
        </li>
      <% end %>

    </ul>
  </div>

</div>
